# Local development only. Do not use in production.
RITOMER_SECURITY_JWT_HMAC_SECRET=local-dev-only-jwt-hmac-secret-change-me
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ritomer
SPRING_DATASOURCE_USERNAME=ritomer
SPRING_DATASOURCE_PASSWORD=ritomer

# Optional PostgreSQL integration tests. Keep disabled by default.
RITOMER_DB_TESTS_ENABLED=false
RITOMER_DB_TEST_JDBC_URL=
RITOMER_DB_TEST_USERNAME=
RITOMER_DB_TEST_PASSWORD=

SPRING_PROFILES_ACTIVE=local
