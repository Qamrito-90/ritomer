{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MappingSuggestion",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "accountId",
    "targetRubricId",
    "confidence",
    "riskLevel",
    "requiresHumanReview",
    "evidence"
  ],
  "properties": {
    "accountId": {
      "type": "string",
      "minLength": 1
    },
    "targetRubricId": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH"
      ]
    },
    "requiresHumanReview": {
      "type": "boolean"
    },
    "rationale": {
      "type": "string",
      "maxLength": 600
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "ref",
          "snippet"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "ACCOUNT_LABEL",
              "HISTORICAL_MAPPING",
              "RULE_DOC",
              "NOTE_TEMPLATE"
            ]
          },
          "ref": {
            "type": "string",
            "maxLength": 200
          },
          "snippet": {
            "type": "string",
            "maxLength": 300
          }
        }
      }
    }
  }
}